# ── MMI Lab Environment Variables ──
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.

# Port the site is accessible on the server (host machine)
# Change this if 8080 conflicts with another service on your server
HOST_PORT=8080

# JWT secret key — generate a strong random string, e.g.:
#   openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-secret-string

# Cloudflare Tunnel token — get this from Cloudflare Zero Trust dashboard
# See setup instructions in SOP-DEPLOYMENT.txt
TUNNEL_TOKEN=your-tunnel-token-here
